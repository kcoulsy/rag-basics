    "hono": "^4.12.23",
    "openai": "^6.42.0",
    "oxfmt": "^0.53.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/vite-dev-server": "^0.26.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
